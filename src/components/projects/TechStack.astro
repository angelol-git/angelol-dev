---
const { mainTech } = Astro.props;
---

<div class="flex flex-col gap-3">
  <h3 class="font-mono uppercase tracking-[0.15em] text-ink-muted">
    Main Tech Stack
  </h3>
  <ul class="flex gap-2">
    {
      mainTech &&
        mainTech.map((item: string) => {
          return (
            <li class="font-mono text-sm border border-ink-muted rounded-full px-3 py-1 text-ink-light">
              {item}
            </li>
          );
        })
    }
  </ul>
</div>
