---
import { MoveLeft } from "@lucide/astro";
const { title } = Astro.props;
---

<div class="flex flex-col gap-4">
  <a
    href="/"
    class="group flex gap-2 items-center w-min transition-colors text-ink-muted hover:text-ink-light"
  >
    <MoveLeft size={18} />
    <span class="font-mono text-sm">Back</span>
  </a>
  <h1 class="font-display text-3xl text-ink leading-tight">
    {title}
  </h1>
  <div class="w-12 h-px bg-accent"></div>
</div>
