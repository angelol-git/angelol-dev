---
import { ArrowUpRight, Globe } from "@lucide/astro";
import Github from "./icons/Github.astro";
import { Image } from "astro:assets";
const { slug, title, url, github, cover, description, mainTech, background } =
  Astro.props;
---

<li
  class="group relative flex flex-col md:flex-row p-5 rounded-xl md:justify-between gap-6 border border-border-custom hover:shadow-lg transition-shadows duration-200"
>
  <div class="flex flex-col gap-3 flex-1">
    <div class="flex flex-col gap-2">
      <a
        href={`/projects/${slug}`}
        class="flex gap-2 items-start after:absolute after:inset-0"
      >
        <div class="flex w-full justify-between items-center">
          <h3 class="font-display text-xl text-ink">{title}</h3>
          <ArrowUpRight size={20} class="text-ink-muted" />
        </div>
      </a>
      <p class="text-sm text-ink-muted leading-relaxed">
        {description}
      </p>
    </div>

    <div class="mt-auto flex flex-col gap-4">
      <ul class="flex flex-wrap gap-2 relative z-10">
        {
          mainTech.map((tag: string) => {
            return (
              <li class="font-mono text-xs px-3 py-1 rounded-full border border-border-custom text-ink-muted">
                {tag}
              </li>
            );
          })
        }
      </ul>

      <div class="flex gap-4 relative z-10">
        {
          url && (
            <a 
              href={url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="text-ink-muted hover:text-accent transition-colors duration-150"
            >
              <Globe
                size={18}
                stroke-width={1.5}
              />
            </a>
          )
        }

        {
          github && (
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-muted hover:text-accent transition-colors duration-150"
            >
              <Github />
            </a>
          )
        }
      </div>
    </div>
  </div>

  <div class="w-full md:w-64 shrink-0 overflow-hidden rounded-lg">
    <Image
      src={cover}
      alt={title}
      class="w-full h-48 md:h-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>
</li>
