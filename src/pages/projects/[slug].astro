---
import { getCollection, render } from "astro:content";
import { MoveLeft, Globe } from "@lucide/astro";
import Layout from "../../layouts/Layout.astro";
import Github from "../../components/icons/Github.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}
const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, url, github, cover, tech } = project.data;
---

<Layout title={title}>
  <main class="flex flex-col h-full w-full max-w-screen-sm gap-6">
    <a href="/" class="flex gap-2 items-center w-min">
      <MoveLeft size={18} />
      <div>Back</div>
    </a>
    <h2 class="text-xl">{title}</h2>
    <div class="flex gap-6 items-center">
      {
        url && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex gap-2 items-center"
          >
            <Globe size={18} class="stroke-1" />
            <div class="text-sm">Live Site</div>
          </a>
        )
      }

      {
        github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex gap-2 items-center group"
          >
            <Github />
            <div class="text-sm duration-150">Source Code</div>
          </a>
        )
      }
    </div>

    <img
      src={cover.src}
      alt={title}
      class="rounded-lg w-full h-auto object-cover shrink-0"
    />

    <div class="flex flex-col gap-6">
      <h3
        class="text-sm text-gray-500 uppercase tracking-widest text-muted-foreground"
      >
        TECH STACK/SKILLS
      </h3>
      <ul class="flex gap-2">
        {
          tech &&
            tech.map((item) => {
              return (
                <li class="text-sm border-1 rounded-full px-3 py-1">{item}</li>
              );
            })
        }
      </ul>
    </div>
    <section class="flex flex-col gap-6 prose content-list max-w-none">
      <Content />
    </section>
  </main>
</Layout>
