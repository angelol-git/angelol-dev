---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
const projects = await getCollection("projects");
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Angelo Ladores">
  <main class="flex flex-col w-full h-full max-w-2xl gap-10">
    <div class="flex flex-col gap-1">
      <p class="font-mono text-sm text-ink-muted">Software Engineer</p>

      <h1 class="text-3xl font-display text-ink">Angelo Ladores</h1>
    </div>
    <div class="flex flex-col gap-3 text-ink-light">
      <p>Software Engineer located in Ontario, Canada.</p>
      <p>
        Currently, I am focusing on building web applications with React and
        Node. My projects range from full-stack applications like <a
          href="/projects/recipe"
          class="text-accent underline decoration-accent-light"
          >AI Recipe Manager</a
        > to front end Chrome Extensions such as <a
          href="/projects/measured"
          class="text-accent underline decoration-accent-light">Measured</a
        >.
      </p>
      <p>
        Towards this goal, I enjoy learning about other web technologies like
        Svelte with <a
          href="/projects/homesaver"
          class="text-accent underline decoration-accent-light">HomeSaver</a
        > or Astro as used in <a
          href="/projects/softlyshaded"
          class="text-accent underline decoration-accent-light">SoftlyShaded</a
        >. Whatever the stack, I'm always trying to find the most effective
        solution that solves the problem.
      </p>
    </div>
    <section class="flex flex-col gap-6">
      <h2 class="font-mono uppercase tracking-[0.15em] text-ink-muted">
        Projects
      </h2>
      <ul class="flex flex-col gap-6">
        {
          sortedProjects.map((project) => (
            <ProjectCard
              slug={project.data.slug}
              title={project.data.title}
              description={project.data.description}
              url={project.data.url}
              github={project.data.github}
              cover={project.data.cover}
              mainTech={project.data.mainTech}
              background={project.data.background}
            />
          ))
        }
      </ul>
    </section>
  </main>
</Layout>
